POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame_secret
DATABASE_URL=postgresql://boardgame:boardgame_secret@localhost:5432/boardgame_catalog

SMB_USERNAME=
SMB_PASSWORD=

# BGG XML API credentials (optional until approved — requests work without it but may be rate-limited)
# Apply at: https://boardgamegeek.com/wiki/page/XML_API_Terms_of_Use
BGG_API_KEY=

# Local LLM server (OpenAI-compatible API, e.g. llama.cpp)
LLM_BASE_URL=http://console.localdomain:8080/v1
LLM_MODEL=default
# LLM_API_KEY=  # only if your server requires auth

# Shared password for write/mutate operations (default: "password")
AUTH_TOKEN=password

# Secret for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=
