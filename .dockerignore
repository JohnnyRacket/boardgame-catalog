# Keep .gitignore in the build context — Next.js and Tailwind read it at build
# time to determine which files to scan/exclude. Omitting it causes broken CSS
# in production Docker builds.
!.gitignore

# Heavy directories that are rebuilt inside the container
node_modules
.next
out
build
coverage

# Local env files (injected at runtime via Docker/Compose env vars)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dev/tooling noise
.git
*.tsbuildinfo
next-env.d.ts
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# Uploads are mounted as a volume at runtime
public/uploads/*
!public/uploads/.gitkeep
